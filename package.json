{
  "name": "ffc-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mini golf scorecard PWA — offline-first, four themed 18-hole courses",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "putt:sim": "node --experimental-strip-types scripts/putt-sim.ts"
  },
  "dependencies": {
