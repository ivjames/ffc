    "@fontsource/cinzel": "^5.3.0",
    "@fontsource/cinzel-decorative": "^5.3.0",
    "@fontsource/exo-2": "^5.3.0",
    "@fontsource/luckiest-guy": "^5.3.0",
    "@fontsource/orbitron": "^5.3.0",
    "@fontsource/shippori-mincho": "^5.3.0",
    "@fontsource/source-sans-3": "^5.3.0",
    "@fontsource/spectral": "^5.3.0",
    "idb": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
