{
  "name": "ffc-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mini golf scorecard PWA — offline-first, four themed 18-hole courses",
  "scripts": {
    "dev": "vite",
    "export-content": "node scripts/export-content.mjs",
    "build": "node scripts/export-content.mjs && tsc -b && vite build",
    "build:admin": "tsc -p tsconfig.admin.json --noEmit && vite build --config vite.admin.config.ts",
    "typecheck:admin": "tsc -p tsconfig.admin.json --noEmit",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "putt:sim": "node --experimental-strip-types scripts/putt-sim.ts",
    "test:admin": "vitest run --config vitest.admin.config.ts",
    "test:admin:watch": "vitest --config vitest.admin.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/baloo-2": "^5.3.0",
    "@fontsource/luckiest-guy": "^5.3.0",
    "@fontsource/orbitron": "^5.3.0",
    "idb": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.5"
  }
}
