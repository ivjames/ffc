# Frontend (Vite) build-time env. Copy to .env / .env.local and fill in.
# Only VITE_-prefixed vars are exposed to the client bundle.

# Base URL for the API. Empty = same origin (nginx proxies /api on the droplet).
VITE_API_BASE=

# Dev mode. Gates development-only affordances: the skin picker (bottom-left),
# the build stamp (bottom-right), and the scorecard/setup "Auto play (test)"
# buttons. Defaults on; set to 'false' to hide all of them without touching code.
VITE_DEV_MODE=

# --- TESTING TOGGLES (remove/leave unset before production) ---
# Allow uploading an existing photo (from the phone's library) for a scavenger
# find, not just a live camera capture. Set to 'true' to enable; unset in
# production so players must take a real photo.
# NOTE: pairs with the server's HUNT_ALLOW_PHOTO_OF_PHOTO (see server/.env.example)
# if you also want screenshots/photos-of-screens to verify.
VITE_HUNT_ALLOW_UPLOAD=
