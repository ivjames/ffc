# Copy to .env and fill in. .env stays local to this app dir (lab980 convention).
DATABASE_URL=postgres://user:pass@localhost:5432/ffc
# Local port the API listens on. The droplet runs many apps on 8060+, so use the
# FREE port provision-site reserved for this site:  grep '^PORT=' ../.env
# (bin/ffc reads this PORT for the nginx vhost, health check, and seeding).
PORT=8060
# Shared token guarding POST /api/seed. If unset, seeding is allowed (dev mode).
APP_TOKEN=
