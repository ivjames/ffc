# Copy to .env and fill in. .env stays local to this app dir (lab980 convention).
DATABASE_URL=postgres://user:pass@localhost:5432/ffc
# Local port the API listens on. The droplet runs many apps on 8060+, so use the
# FREE port provision-site reserved for this site:  grep '^PORT=' ../.env
# (bin/ffc reads this PORT for the nginx vhost, health check, and seeding).
PORT=8060
# Shared token guarding POST /api/seed, POST /api/locations, and all of
# /api/admin/*. REQUIRED — if unset, those routes fail closed (401 on every
# request, including on a local dev box). Set this before using any of them.
APP_TOKEN=
# Fallback timezone for the leaderboard's calendar windows (day/week/month are
# tracked by calendar date, not a rolling 24h/7d/30d). The real zone is per venue
# (location.tz in the DB), so venues in different regions each use their own
# calendar day; this VENUE_TZ is only the default for a venue with no tz set.
VENUE_TZ=America/Los_Angeles

# --- TESTING TOGGLES (remove/leave unset before production) ---
# TEST ONLY — must not be set in production. Bypasses the scavenger-hunt
# anti-cheat so a screenshot or a picture of a screen still verifies a
# landmark. Truthy (1/true/yes/on) enables it. Leave UNSET in production to
# keep the photo-of-a-photo check active; if NODE_ENV=production and this is
# still set truthy, the server forces it off itself and logs a warning.
HUNT_ALLOW_PHOTO_OF_PHOTO=
